/*
  # Proteção contra Clickjacking — impede que o app seja embutido em iframes
  X-Frame-Options: DENY

  # Impede MIME-type sniffing (execução de arquivos com tipo errado)
  X-Content-Type-Options: nosniff

  # Ativa proteção XSS em navegadores antigos
  X-XSS-Protection: 1; mode=block

  # Não vaza a URL de origem ao navegar para outros domínios
  Referrer-Policy: strict-origin-when-cross-origin

  # Restringe APIs de hardware sensíveis
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=(), usb=(), bluetooth=()

  # Força HTTPS por 1 ano e inclui subdomínios
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Content Security Policy — mesma política do index.html mas via header HTTP (tem precedência)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://*.tile.openstreetmap.org https://*.supabase.co https://*.supabase.in; connect-src 'self' https://*.supabase.co https://*.supabase.in wss://*.supabase.co https://api.open-meteo.com https://brasilapi.com.br https://nominatim.openstreetmap.org https://viacep.com.br; worker-src 'self' blob:; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests;

  # Remove o header padrão do servidor (não expõe tecnologia usada)
  X-Powered-By:
  Server:

  # Política de cache para assets estáticos — cacheados por 1 ano (nomes com hash)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

  # HTML nunca cacheado (sempre pega versão fresca)
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

  # Service Worker nunca cacheado
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
