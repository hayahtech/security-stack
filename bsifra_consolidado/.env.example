# =============================================================================
# Variáveis de ambiente — bsifra (HayaH Tech)
# Repositório: https://github.com/hayahtech/bsifra
#
# INSTRUÇÕES:
#   1. Copie: cp .env.example .env
#   2. Preencha os valores reais
#   3. NUNCA commite o .env (já está no .gitignore)
#
# ATENÇÃO: a PUBLISHABLE_KEY é a anon key pública do Supabase — não é secreta.
#          A service_role key NUNCA deve aparecer aqui nem ser commitada.
# =============================================================================

# Supabase — https://supabase.com/dashboard/project/<id>/settings/api
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PROJECT_ID=seu-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=sua-anon-key-publica

# Dados da empresa (exibidos nos orçamentos gerados)
VITE_COMPANY_NAME=Sua Empresa
VITE_COMPANY_CNPJ=00.000.000/0001-00
VITE_COMPANY_PHONE=(00) 00000-0000
VITE_COMPANY_WEBSITE=www.seusite.com.br
